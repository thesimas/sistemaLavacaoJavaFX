<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane id="AnchorPane" prefHeight="429.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.edu.ifsc.fln.sistemalavacaojavafx.controller.FXMLAnchorPaneGraficoPorMesController">
    <children>
        <BarChart fx:id="barChart" layoutX="33.0" layoutY="14.0" prefHeight="342.0" prefWidth="500.0" title="Vendas por Mês">
            <xAxis>
                <CategoryAxis fx:id="categoryAxis" side="BOTTOM" />
            </xAxis>
            <yAxis>
                <NumberAxis fx:id="numberAxis" side="LEFT" />
            </yAxis>
        </BarChart>
      <Button fx:id="btFechar" layoutX="410.0" layoutY="371.0" mnemonicParsing="false" onAction="#handleBtFechar" prefHeight="26.0" prefWidth="122.0" text="Voltar para o Menu" />
    </children>
</AnchorPane>
